@inject Leo.Project.Portfolio.Web.Services.ThemeService ThemeService
<section id="portfolio-gallery" class="portfolio-gallery" style="padding: 100px 0; background-color: var(--gh-bg);">
    <div class="container">
        <div class="text-center mb-16">
            <MudText Typo="Typo.h6" Style="color: var(--gh-green-3); font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px;">Professional Impact</MudText>
            <MudText Typo="Typo.h3" Style="font-weight: 800; color: var(--gh-text);">Work Experience</MudText>
        </div>

    <div class="modern-experience-list">
        <!-- Blackfort Section -->
        <div class="exp-row reveal stagger-1">
            <div class="exp-logo-area">
                <img src="blackfort-logo-black.webp" alt="Blackfort PH - Software Engineering & Cloud Solutions Company Logo" class="large-exp-logo" loading="lazy" style="filter: @(ThemeService.IsDarkMode ? "drop-shadow(1px 1px 0 white) drop-shadow(-1px -1px 0 white) drop-shadow(1px -1px 0 white) drop-shadow(-1px 1px 0 white)" : "drop-shadow(1px 1px 0 black) drop-shadow(-1px -1px 0 black) drop-shadow(1px -1px 0 black) drop-shadow(-1px 1px 0 black)");" />
            </div>
            <div class="exp-info-area">
                <MudText Typo="Typo.h4" Class="exp-company">Blackfort</MudText>
                <MudText Typo="Typo.body2" Class="exp-industry">Industry: Software Engineering & Cloud Solutions</MudText>
                <MudText Typo="Typo.body1" Class="exp-description">
                    Contributed as a key developer at Blackfort, primarily the developer of the native Mobile Application
                    for infrastructure monitoring. Collaborated on the development of high-performance web-based dashboards, 
                    ensuring seamless integration for real-time data tracking and offline support across multiple platforms.
                </MudText>
            </div>
        </div>

        <!-- Provincial Gov Section -->
        <div class="exp-row reverse reveal stagger-2">
            <div class="exp-logo-area">
                <img src="provincial misamis.png" alt="Provincial Government of Misamis Oriental - Public Sector Digital Transformation Logo" class="large-exp-logo" loading="lazy" />
            </div>
            <div class="exp-info-area">
                <MudText Typo="Typo.h4" Class="exp-company">Provincial Gov. of Misamis Oriental</MudText>
                <MudText Typo="Typo.body2" Class="exp-industry">Industry: Public Sector & Governance</MudText>
                <MudText Typo="Typo.body1" Class="exp-description">
                    Implemented the digital transformation of government services. Integrated the Electronic 
                    Leave Application System and various citizen-facing portals that improved administrative efficiency 
                    across all provincial departments.
                </MudText>
            </div>
        </div>
        
        <!-- DSWD Section -->
        <div class="exp-row reveal stagger-3">
            <div class="exp-logo-area">
                <img src="DSWD-Logo-700x394.png" alt="Department of Social Welfare and Development - Government Agency Logo" class="large-exp-logo" loading="lazy" />
            </div>
            <div class="exp-info-area">
                <MudText Typo="Typo.h4" Class="exp-company">Dept. of Social Welfare & Development</MudText>
                <MudText Typo="Typo.body2" Class="exp-industry">Industry: Social Services / Government</MudText>
                <MudText Typo="Typo.body1" Class="exp-description">
                    Developed high-integrity Document Management Systems at scale. Engineered the underlying OCR and 
                    indexing engines that allow social workers to instantly retrieve and process citizen records with 
                    perfect accuracy.
                </MudText>
            </div>
        </div>

        <!-- SVI Section -->
        <div class="exp-row reverse reveal stagger-4">
            <div class="exp-logo-area">
                <img src="W-SVI Logos_SVI Corporation.avif" alt="SVI Corporation - Software Ventures International Corporate Logo" class="large-exp-logo" loading="lazy" style="filter: @(ThemeService.IsDarkMode ? "" : "drop-shadow(1px 1px 0 black) drop-shadow(-1px -1px 0 black) drop-shadow(1px -1px 0 black) drop-shadow(-1px 1px 0 black)");" />
            </div>
            <div class="exp-info-area">
                <MudText Typo="Typo.h4" Class="exp-company">Software Venture International</MudText>
                <MudText Typo="Typo.body2" Class="exp-industry">Industry: Corporate Software Services</MudText>
                <MudText Typo="Typo.body1" Class="exp-description">
                    Pioneered the data capture initiative for large-scale OCR digitization projects. Led a cross-functional team in transforming historical government records into secure, digital assets.
                </MudText>
            </div>
        </div>
    </div>
</div>
</section>

<style>
    .modern-experience-list {
        display: flex;
        flex-direction: column;
        gap: 120px;
        padding-top: 60px;
    }

    .exp-row {
        display: flex;
        align-items: center;
        gap: 100px;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s forwards;
    }

    .exp-row.reverse {
        flex-direction: row-reverse;
    }

    .exp-logo-area {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .large-exp-logo {
        max-width: 100%;
        max-height: 200px;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .exp-row:hover .large-exp-logo {
        transform: scale(1.05);
    }

    .exp-info-area {
        flex: 1;
    }

    .exp-company {
        color: var(--gh-text);
        font-weight: 800 !important;
        margin-bottom: 8px !important;
        letter-spacing: -1px;
    }

    .exp-industry {
        color: var(--gh-green-4);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 24px !important;
        display: block;
    }

    .exp-description {
        color: var(--gh-text-muted);
        line-height: 1.8 !important;
        font-size: 1.1rem !important;
    }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 992px) {
        .exp-row, .exp-row.reverse {
            flex-direction: column;
            gap: 40px;
            text-align: center;
        }
        
        .modern-experience-list {
            gap: 80px;
        }

        .large-exp-logo {
            max-height: 120px;
        }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}