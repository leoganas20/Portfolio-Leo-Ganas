

<section id="skills" style="padding: 80px 0; background-color: var(--gh-bg);">
    <div class="container">
        <div class="skills-container" style="background: var(--gh-canvas); border: 1px solid var(--gh-border); border-radius: 12px; padding: 40px;">
            <div class="d-flex align-center mb-8">
                <MudIcon Icon="@Icons.Material.Filled.Code" Style="color: var(--gh-primary); font-size: 32px; margin-right: 16px;" />
                <MudText Typo="Typo.h2" Style="font-weight: 800; color: var(--gh-text); font-size: 28px;">Technical Expertise</MudText>
            </div>

            <div class="skills-section mb-10">
                <div class="d-flex align-center mb-4">
                    <img src="images/microsoftlogo.png" style="width: 20px; height: 20px; object-fit: contain; margin-right: 12px;" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: var(--gh-text);">Microsoft Tech Stack</MudText>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var skill in MicrosoftSkills)
                    {
                        <div class="skill-tag">
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: var(--gh-green-3); margin-right: 6px;" />
                            <span>@skill</span>
                        </div>
                    }
                </div>
            </div>

            <div class="skills-section">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Extension" Size="Size.Small" Style="color: var(--gh-text-muted); margin-right: 12px;" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600; color: var(--gh-text);">Specialized Skills</MudText>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var skill in OtherSkills)
                    {
                        <div class="skill-tag secondary">
                            <span>@skill</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private string[] MicrosoftSkills = new[] { 
        "C#", ".NET 8", ".NET 9", "Blazor", "Blazor WebAssembly","Blazor Server-Side", "ASP.NET Core", "CQRS", "Dependency Injection", ".NET MAUI", "SQL Server", 
        "Entity Framework", "IDP", "Entra ID", "Azure DevOps", "CI/CD Pipelines", 
        "Web API", "Blazor Hybrid", "Bootstrap", "CSS","HTML", "Javascript", "Postman"
        ,"NSwagg", "OpenApi"
    };

    private string[] OtherSkills = new[] { 
        "Unity 3D/2D", "WebGL", "WordPress", "Full Stack .NET Development", 
        "UI/UX Implementation", "Problem Solving", "Clean Architecture" 
    };
}

<style>
    .skill-tag {
        display: flex;
        align-items: center;
        background: var(--gh-bg);
        border: 1px solid var(--gh-border);
        border-radius: 20px;
        padding: 6px 16px;
        font-size: 14px;
        color: var(--gh-text);
        font-weight: 500;
        transition: all 0.2s;
    }
    .skill-tag:hover {
        border-color: var(--gh-green-3);
        transform: translateY(-2px);
    }
    .skill-tag.secondary {
        background: transparent;
        color: var(--gh-text-muted);
    }
    .skill-tag.secondary:hover {
        border-color: var(--gh-text);
        color: var(--gh-text);
    }
</style>