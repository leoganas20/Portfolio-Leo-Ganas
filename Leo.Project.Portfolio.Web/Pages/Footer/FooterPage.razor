@inject IJSRuntime JSRuntime
@inject Leo.Project.Portfolio.Web.Services.ThemeService ThemeService

<footer id="contact" class="footer" style="background-color: var(--gh-canvas); border-top: 1px solid var(--gh-border); color: var(--gh-text-muted); padding: 40px 0; text-align: center;">
    <div class="container">
        <div class="d-flex flex-column align-center">
            <p class="m-0" style="font-size: 14px;">&copy; 2020 LG Dev Software. All Rights Reserved.</p>
            <p style="font-size: 12px; opacity: 0.7;">Built with .NET Blazor & MudBlazor</p>
            
            <div class="icon-container d-flex mt-4">
                <img @onclick="@(() => OnRedirect("https://www.linkedin.com/in/leo-ganas-468b50212/"))" src="images/icons/icons8-linkedin-logo-30.png" alt="LinkedIn Leonardo Ganas Portfolio" width="24" style="object-fit:contain; filter: @(ThemeService.IsDarkMode ? "brightness(0) invert(1)" : "brightness(0)"); opacity: 0.6;" />
                <img @onclick="@(() => OnRedirect("https://www.upwork.com/freelancers/~016297b0547fe38cce?mp_source=share"))" src="images/icons/icons8-upwork-30.png" alt="Upwork Leonardo Ganas Portfolio" width="24" style="object-fit:contain; filter: @(ThemeService.IsDarkMode ? "brightness(0) invert(1)" : "brightness(0)"); opacity: 0.6;" />
                <img @onclick="@(() => OnRedirect("https://wa.me/+639161452948"))" src="images/icons/icons8-whatsapp-30.png" alt="WhatsApp Leonardo Ganas" width="24" style="object-fit:contain; filter: @(ThemeService.IsDarkMode ? "brightness(0) invert(1)" : "brightness(0)"); opacity: 0.6;" />
                <img @onclick="@(() => OnRedirect("https://mail.google.com/mail/u/0/#inbox?compose=GTvVlcSGKnGfxbxVDpCxhtFWHfPHfvTPqJmWTrtxMmcHFvBthwHQwGKXBSzzVggMvzkNstFBQfBbc"))" src="images/icons/icons8-gmail-logo-30.png" alt="Email Leonardo Ganas" width="24" style="object-fit:contain; filter: @(ThemeService.IsDarkMode ? "brightness(0) invert(1)" : "brightness(0)"); opacity: 0.6;" />
            </div>
        </div>
    </div>
</footer>

<style>
    .icon-container img {
        margin: 0 10px;
        transition: transform 0.3s ease;
        cursor: pointer;
    }

    .icon-container img:hover {
        transform: scale(1.2);
    }
</style>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    void OnRedirect(string url)
    {
        JSRuntime.InvokeVoidAsync("window.open", url, "_blank");
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}
