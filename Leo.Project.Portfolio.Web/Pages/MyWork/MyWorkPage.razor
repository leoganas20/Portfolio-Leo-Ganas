@using Leo.Project.Portfolio.Web.Pages.MyWork.Model;


<section id="my-work" class="my-work" style="background-color: var(--gh-bg); border-top: 1px solid var(--gh-border); padding: 100px 0;">
    <div class="container">
        <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--gh-text); text-align: center; margin-bottom: 12px;">Accomplishments</MudText>
        <MudText Typo="Typo.subtitle1" Style="color: var(--gh-text-muted); text-align: center; margin-bottom: 60px;">A selection of impact-driven solutions developed for diverse industries.</MudText>
        <MudCard Elevation="0" Class="accomplishment-card">
