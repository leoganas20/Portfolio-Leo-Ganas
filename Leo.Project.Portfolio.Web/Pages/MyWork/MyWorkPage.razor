                        <div class="row">
                            <div class="col-12">
                                <MudText Typo="Typo.h6" Style="font-weight: bolder">Multi Platform Development (Blackfort PH)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: normal; color: var(--gh-primary);">Responsive Web App & Native Mobile App</MudText>
                                <MudText Typo="Typo.subtitle1">
                                    With 5+ years of experience in Blazor and .NET, I specialized in developing infrastructure monitoring and inspection systems. My focus was on capturing real-time data, including photos, GPS geolocation, and offline support, enabling seamless integration between mobile and web platforms.
                                </MudText>
                            </div>
                            <div class="col-12 d-flex justify-content-between mt-5 gap-5">

                                <MudGrid>
                                    <MudItem xs="12" sm="12" lg="6" md="6">
                                        <div class="web-notes">
                                            <MudIcon Icon="@Icons.Material.Filled.Web" Size="Size.Large" Color="Color.Success" />
                                            <MudText Typo="Typo.h6">Web Development</MudText>
                                            <MudText Typo="Typo.subtitle1">
                                                I’ve built intuitive dashboards for web-based infrastructure management, allowing administrators to monitor inspection data, track site locations, and generate reports.
                                            </MudText>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="12" sm="12" lg="6" md="6">
                                        <div class="mobile-notes">
                                            <MudIcon Icon="@Icons.Material.Filled.Smartphone" Size="Size.Large" Color="Color.Success" />
                                            <MudText Typo="Typo.h6">Mobile Development</MudText>
                                            <MudText Typo="Typo.subtitle1">
                                                I develop mobile solutions for site inspections, enabling field agents to capture geolocated photos and data offline. Once online, the data is automatically synced to the server for processing.
                                            </MudText>
                                        </div>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudItem>
                    <MudItem Class="project" xs="12" sm="12" lg="6"  md="12" Style="position: relative;">
