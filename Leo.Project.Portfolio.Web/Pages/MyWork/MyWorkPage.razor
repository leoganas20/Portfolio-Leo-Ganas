        <!-- Electronic Leave Application System (Provincial Government) -->
        <MudCard Elevation="0" Class="accomplishment-card" Style="margin-top: 100px;">
            <MudCardContent Class="d-flex justify-content-center">
                <MudGrid Class="element-grid" Style="width:100%">
                    <MudItem xs="12" sm="12" lg="6" md="12" Class="summar-project">
                        <div class="row">
                            <div class="col-12">
                                <MudText Typo="Typo.h6" Style="font-weight: bolder">Electronic Leave Application System (Provincial Government)</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: normal; color: var(--gh-primary);">Progressive Web App (PWA) using Blazor WebAssembly</MudText>
                                <MudText Typo="Typo.subtitle1">
                                    Designed and deployed a digital leave application system, replacing manual paper-based processes. The system features automated approval workflows, real-time tracking, and employee training modules.
                                </MudText>
                            </div>
                            <div class="col-12 d-flex justify-content-between mt-5 gap-5">
                                <MudGrid>
                                    <MudItem xs="12" sm="12" lg="6" md="6">
                                        <div class="web-notes">
                                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Success" />
                                            <MudText Typo="Typo.h6">PWA Features</MudText>
                                            <MudText Typo="Typo.subtitle1">
                                                Fast, reliable, and accessible on any device. Offline support allows employees to draft applications even without an internet connection.
                                            </MudText>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="12" sm="12" lg="6" md="6">
                                        <div class="mobile-notes">
                                            <MudIcon Icon="@Icons.Material.Filled.Rule" Size="Size.Large" Color="Color.Success" />
                                            <MudText Typo="Typo.h6">Automated Workflows</MudText>
                                            <MudText Typo="Typo.subtitle1">
                                                Streamlined approval process from department heads to HR, significantly reducing processing time and paper waste.
                                            </MudText>
                                        </div>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </div>
                    </MudItem>
