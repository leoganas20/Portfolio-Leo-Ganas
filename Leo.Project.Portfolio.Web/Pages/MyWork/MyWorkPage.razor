                                                <MudText Typo="Typo.caption" Style="color: #94a3b8; font-weight: 600;">AVAILABLE BALANCE</MudText>
                                                <div class="d-flex align-end gap-2 mt-1">
                                                    <MudText Typo="Typo.h5" Style="color: #fff; font-weight: 700;">14.5 Days</MudText>
                                                    <MudText Typo="Typo.caption" Style="color: #10b981; margin-bottom: 4px;">+2.5 this month</MudText>
                                                </div>
                                                <div class="mt-4">
