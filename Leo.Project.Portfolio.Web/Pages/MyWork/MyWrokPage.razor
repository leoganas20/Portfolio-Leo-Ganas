   .top-section{
       padding: 10px 20px 1px 20px;
   }
    .mobile-section {
        width: 280px; /* iPhone 14 Pro Max width */
        height: 520px; /* iPhone 14 Pro Max height */
        border-radius: 50px; /* Rounded corners to mimic iPhone's sleek edges */
        background-color: #131a1c; /* White screen background */
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.1); /* Soft shadow to make it look like it's lifted */
        position: relative;
        margin: 0 auto; /* Centers the div */
        overflow: hidden; /* Ensures content stays inside */
        /* Adding a case-like border */
        border: 10px solid #424242; /* Dark grey border resembling the iPhone's frame (like a case) */
        background: linear-gradient(145deg, #131a1c, #2C3639); /* Slight gradient for a premium look */
    }

        /* Dynamic Island (camera notch) */
        .mobile-section::before {
            content: '';
            position: absolute;
            top: 10px; /* Position near the top of the div */
            left: 50%;
            transform: translateX(-50%);
            width: 80px; /* The width of the Dynamic Island */
            height: 25px; /* Height of the pill-shaped camera area */
            background-color: #000; /* Dark background for the camera section */
            border-radius: 30px; /* Rounded corners for the pill shape */
        }

         
        /* Bottom home indicator */
        .mobile-section .home-indicator {
            content: '';
            position: absolute;
            bottom: 15px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 5px;
            background-color: #ccc; /* Button or home indicator */
            border-radius: 10px;
        }

        /* Volume buttons */
        .mobile-section .volume-buttons {
            position: absolute;
            left: 25px; /* Positioning it correctly on the left side */
            top: 150px; /* Adjust height to fit the button's location */
            width: 10px;
            height: 60px;
            z-index: 1;
        }

            /* Volume buttons */
            .mobile-section .volume-buttons::before,
            .mobile-section .volume-buttons::after {
                content: '';
                position: absolute;
                width: 10px;
                height: 15px;
                background-color: #1C1C1C; /* Dark color for the buttons */
                border-radius: 5px;
            }

            .mobile-section .volume-buttons::before {
                top: 0;
            }

            .mobile-section .volume-buttons::after {
                bottom: 0;
            }

        /* Power button (Right side) */
        .mobile-section .power-button {
            position: absolute;
            right: 25px; /* Positioning it correctly on the right side */
            top: 300px; /* Adjust position for power button */
            width: 10px;
            height: 40px;
            background-color: #1C1C1C; /* Dark color for the button */
            border-radius: 5px;
        }

        /* Mute switch (Left side near the volume buttons) */
        .mobile-section .mute-switch {
            position: absolute;
            left: 25px; /* Positioning near the volume buttons on the left side */
            top: 220px; /* Adjust position for mute switch */
            width: 20px;
            height: 8px;
            background-color: #1C1C1C; /* Dark color for the mute switch */
            border-radius: 10px;
        }

    /* General Table Styling */
    .inspection-table {
        width: 100%;
        border-collapse: collapse;
        font-family: Arial, sans-serif;
        margin: 10px 0;
        
        font-size: 12px; /* Smaller font size for compactness */
    }

        .inspection-table th,
        .inspection-table td {
            padding: 8px; /* Reduced padding */
            text-align: left;
            border-bottom: 1px solid #ddd;
            background-color: #f4f4f4;

        }

        .inspection-table th {
            background-color: #f4f4f4;
            color: #333;
            font-weight: bold;
        }

        .inspection-table tbody tr:hover {
            background-color: #f1f1f1;
        }

        .inspection-table td {
            font-size: 12px; /* Consistent smaller font size for data */
        }

