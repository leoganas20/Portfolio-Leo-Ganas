    private string _searchString;
    private bool _sortNameByLength;
    private List<string> _events = new List<string>();

    private Func<InspectionData, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.AssetType.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Defects.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if ($"{x.AssetId} {x.ConditionRating} {x.Status}".Contains(_searchString))
            return true;

        return false;
    };

    private Func<InspectionData, object> _sortBy => x =>
    {
        if (_sortNameByLength)
            return x.AssetType.Length;
        else
            return x.AssetType;
    };

    void RowClicked(DataGridRowClickEventArgs<InspectionData> args)
    {
        _events.Insert(0, $"Event = RowClick, Index = {args.RowIndex}, Data = {System.Text.Json.JsonSerializer.Serialize(args.Item)}");
    }

    void RowRightClicked(DataGridRowClickEventArgs<InspectionData> args)
    {
        _events.Insert(0, $"Event = RowRightClick, Index = {args.RowIndex}, Data = {System.Text.Json.JsonSerializer.Serialize(args.Item)}");
    }

    void SelectedItemsChanged(HashSet<InspectionData> items)
    {
        _events.Insert(0, $"Event = SelectedItemsChanged, Data = {System.Text.Json.JsonSerializer.Serialize(items)}");
    }
}
<style>

    .mud-table-container {
        overflow-x: hidden;
        overflow-y: hidden;
        width: 100%;
        table-layout: fixed;
    }
    .chart-text .mud-typography-body2 {
        font-size: 10px;
    }
    .banner-font {
        font-size: 12px;
        color: black;
        width: 200px;
    }

    .task-text {
        position: relative; /* Allow the h4 to layer above its surroundings */
        z-index: 2; /* Ensure it has a higher z-index than the background pseudo-element */
        white-space: nowrap; /* Prevent text wrapping */
        overflow: hidden; /* Prevent text from spilling out */

        max-width: 100%; /* Restrict to container width */
        font-size: 30px; /* Adjust size as needed */
        
        color: #7F56D9;
        text-align: center
    }

    .separator-v {
        border-right: 1px solid #d3d3d3
    }

    .firstname-text {
        position: relative; /* Allow the h4 to layer above its surroundings */
        z-index: 2; /* Ensure it has a higher z-index than the background pseudo-element */
        white-space: nowrap; /* Prevent text wrapping */
        overflow: hidden; /* Prevent text from spilling out */

        max-width: 100%; /* Restrict to container width */
        font-size: 17px; /* Adjust size as needed */
        color: #333; /* Ensure high contrast with the background */
    }

    .remaining-text {
        position: relative; /* Allow the h4 to layer above its surroundings */
        z-index: 2; /* Ensure it has a higher z-index than the background pseudo-element */
        white-space: nowrap; /* Prevent text wrapping */
        overflow: hidden; /* Prevent text from spilling out */

        max-width: 100%; /* Restrict to container width */
        font-size: 13px; /* Adjust size as needed */
        color: #333; /* Ensure high contrast with the background */
    }
    .custom-background {
        position: relative; /* Establish stacking context for the pseudo-element */
        overflow: hidden; /* Ensure the pseudo-element doesn't spill outside */
        
    }

        .custom-background::after {
            content: '';
            position: absolute;
            top: 0;
            right: 11px; /* Align the gradient to the right */
            bottom: 0;
            left: auto; /* Prevent overriding with left positioning */
            width: 60%; /* Adjust the gradient width */
            background-image: linear-gradient(to left, rgba(255, 255, 255, 0) 30%, rgba(255, 255, 255, 1) 100%), url("/images/inspection-banner.png");
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            height: 110px;
            z-index: 1; /* Ensure it is layered behind the content */
        }


    .banner-container {
        padding-block: 0rem;
        padding-inline: 0rem;
    }
    .mud-badge.mud-badge-top.right.mud-badge-overlap {
        inset: auto auto calc(100% - 9px) calc(100% - 9px);
    }

    .mud-badge {
        border-radius: 10px;
        font-size: 7px;
        height: 15px;
        letter-spacing: 0;
        min-width: 15px;
        padding: 4px 6px;
        pointer-events: auto;
        line-height: 1;
        position: absolute;
        text-align: center;
        text-indent: 0;
        top: auto;
        transition: .3s cubic-bezier(0.25, 0.8, 0.5, 1);
        white-space: nowrap;
    }
    .mud-nav-link .mud-nav-link-text {
        width: 100%;
        text-align: start;
        margin-left: 12px;
        margin-inline-start: 12px;
        margin-inline-end: unset;
        letter-spacing: 0;
        color: white;
    }

