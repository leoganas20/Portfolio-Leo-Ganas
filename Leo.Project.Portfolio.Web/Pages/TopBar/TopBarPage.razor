@using MudBlazor.Services
@using Leo.Projects.Portfolio.Web.Pages.ComponentPageBase;
@implements IBrowserViewportObserver
@implements IAsyncDisposable  
@inject IJSRuntime JS
@inherits ComponentPageBase
<header class="top-bar" style="background-color: var(--gh-bg); border-bottom: 1px solid var(--gh-border); color: var(--gh-text);">
    <div class="container">
        <div class="logo">
            <img src="/images/LGdevLogo.png" width="100" style="object-fit: contain; filter: brightness(0) invert(1);">
        </div>
        @if (new[] { Breakpoint.Xs, Breakpoint.Sm }.Contains(updateBreakpoint))
        {
             <div class="btn-group">
                <MudChip T="string" Style="background-color: var(--gh-primary); color: white;" Class="mx-5" Disabled="@_processing" OnClick="ProcessSomething" Variant="Variant.Filled">
                    @if (_processing)
                    {
                        <MudText Class="mx-2">Processing</MudText>
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" Style="color: white;" />
                            <MudText Class="ml-1" Style="color: white;">CV</MudText>
                        </div>
                    }
                </MudChip>

                <MudIcon Class="mt-1 burger-btn" @onclick="OnExpandCollapseClick"
                         Icon="@Icons.Material.Filled.Menu"
                         Style="color: var(--gh-text); font-size: 32px;"
                         Size="Size.Large" />
             </div>
        }
        else
        {
            <nav>
                <ul class="nav-list">
                    <li><a href="#hero-section" style="color: var(--gh-text);">Home</a></li>
                    <li><a href="#services" style="color: var(--gh-text);">Services</a></li>
                    <li><a href="#skills" style="color: var(--gh-text);">Skills</a></li>
                    <li><a href="#portfolio-gallery" style="color: var(--gh-text);">Experience</a></li>
                    <li><a href="#contact" style="color: var(--gh-text);">Contact</a></li>
                    <li class="chip-item">
                        <MudChip T="string" Style="background-color: var(--gh-primary); color: white; height: 32px; border-radius: 6px;"
                                 Class="mx-5 px-4"
                                 Disabled="@_processing"
                                 OnClick="ProcessSomething"
                                 Variant="Variant.Filled">
                            @if (_processing)
                            {
                                <MudText Class="mx-2" Style="color: white;">Processing</MudText>
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" Style="color: white;" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" Style="color: white;" />
                                <MudText Style="font-weight: 600; font-size: 14px; color: white;" Class="ml-2 text-white">Download CV</MudText>
                               
                            }
                        </MudChip>
                    </li>
                </ul>
            </nav>
        }
    </div>

    <MudDrawer Style="color: var(--gh-text); background-color: var(--gh-canvas); border-left: 1px solid var(--gh-border);" @bind-Open="@_expanded" Anchor="@_anchor" Elevation="0" Variant="@DrawerVariant.Temporary" OverlayAutoClose="@_overlayAutoClose">
        <MudDrawerHeader Class="d-flex justify-content-between">
            <MudText Typo="Typo.h6" Style="color: var(--gh-text);">Menu</MudText>
            <MudIcon Class="burger-btn" @onclick="OnExpandCollapseClick" Icon="@Icons.Material.Filled.Close" Style="color: var(--gh-text); font-size: 32px;" Size="Size.Large" />
        </MudDrawerHeader>
        <MudNavMenu Style="background: var(--gh-canvas)">
            <MudPaper Width="auto" Class="py-3" Elevation="0" Style="background: transparent;">
                <MudNavMenu Bordered="true">
                    <MudNavLink Style="color: var(--gh-text)" Href="#hero-section">Home</MudNavLink>
                    <MudNavLink Style="color: var(--gh-text)" Href="#services">Services</MudNavLink>
                    <MudNavLink Style="color: var(--gh-text)" Href="#skills">Skills</MudNavLink>
                    <MudNavLink Style="color: var(--gh-text)" Href="#portfolio-gallery">Experience</MudNavLink>
                    <MudNavLink Style="color: var(--gh-text)" Href="#contact">Contact</MudNavLink>
                </MudNavMenu>
            </MudPaper>
        </MudNavMenu>
    </MudDrawer>
    <MudOverlay @bind-Visible="_expanded" DarkBackground />
</header>
 

@code{
    [Inject]  private IBrowserViewportService BrowserViewportService { get; set; }

    private List<Breakpoint> _breakpointHistory = new();
    private Breakpoint _start;
    private Breakpoint updateBreakpoint;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BrowserViewportService.SubscribeAsync(this, fireImmediately: true);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public async ValueTask DisposeAsync() => await BrowserViewportService.UnsubscribeAsync(this);

    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();

    ResizeOptions IBrowserViewportObserver.ResizeOptions { get; } = new()
        {
            ReportRate = 250,
            NotifyOnBreakpointOnly = true
        };

    Task IBrowserViewportObserver.NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs browserViewportEventArgs)
    {
        if (browserViewportEventArgs.IsImmediate)
        {
            _start = browserViewportEventArgs.Breakpoint;
        }
        else
        {
            _breakpointHistory.Add(browserViewportEventArgs.Breakpoint);
        }
        updateBreakpoint = browserViewportEventArgs.Breakpoint;
        return InvokeAsync(StateHasChanged);
    }

    bool _expanded = false;

    private void OnExpandCollapseClick()
    {
        _expanded = !_expanded;
        if(!_expanded){
            IsExpandedMenu = false;
        }
        StateHasChanged();
    }

    private Anchor _anchor = Anchor.Top;
    private bool _overlayAutoClose = true;

    private void OpenDrawer(Anchor anchor)
    {
        _expanded = true;
        _anchor = anchor;
    }

    private bool IsExpandedMenu = false;
    private void OnExpandMenu(){
        IsExpandedMenu = !IsExpandedMenu;
    }

    private void ExpandedMenuChanged(){
        _expanded = false;
        IsExpandedMenu = false;
        StateHasChanged();
    }

    private bool _processing = false;

    async Task ProcessSomething()
    {
        _processing = true;
        await Task.Delay(1000);
        await JS.InvokeVoidAsync("downloadCv");
        _processing = false;
    }
}
<style>
    .glow {
        color: #fff; /* White color for the text */
        text-shadow: 0 0 5px #B1C29E, /* Red glow */
        0 0 10px #B1C29E, /* Stronger red glow */
        0 0 15px #B1C29E, /* Even stronger red glow */
        0 0 20px #B1C29E; /* Strong red glow */
    }

    .mud-icon-button {
        flex: 0 0 auto;
        padding: 12px;
        overflow: visible;
        font-size: 1.5rem;
        text-align: center;
        transition: background-color 150ms cubic-bezier(0.4, 0, 0.2, 1) 0ms;
        border-radius: 50%;
        color: white;
    }

    .mud-navmenu.mud-navmenu-dark .mud-nav-link.active:not(.mud-nav-link-disabled){
        color: #596E79;
        --mud-ripple-color: var(--mud-palette-dark);
        background-color: var(--mud-palette-dark-hover);
        font-size: 16px;
    }
    
</style>